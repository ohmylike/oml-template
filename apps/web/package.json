{
  "name": "@oml-__SERVICE_NAME__/web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && tsdown",
    "dev": "vite build && (vite build --watch & wrangler dev)",
    "dev:vite": "vite",
    "deploy": "vite build --mode production && wrangler deploy --env production",
    "deploy:preview": "wrangler deploy --name ${PREVIEW_WORKER}-web --var API_ORIGIN:https://${PREVIEW_WORKER}-api.ohmylike.workers.dev"
  },
  "dependencies": {
    "@oml-__SERVICE_NAME__/api-client": "workspace:*",
    "@oml-__SERVICE_NAME__/core": "workspace:*",
    "@tanstack/react-query": "^5.90",
    "@tanstack/react-router": "^1.166",
    "hono": "^4.12",
    "react": "^19.2",
    "react-dom": "^19.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@tailwindcss/vite": "^4.2",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "@vitejs/plugin-react": "^5.1",
    "tailwindcss": "^4.2",
    "tsdown": "^0.21",
    "typescript": "^5.9",
    "vite": "^7.3",
    "wrangler": "^4"
  }
}
